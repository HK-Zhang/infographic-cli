{
  "name": "infog-cli",
  "version": "0.0.1",
  "description": "Instantly create stunning SVG infographics from simple declarative syntax. Render from strings, files, or stdin.",
  "license": "MIT",
  "author": "HK-Zhang",
  "type": "module",
  "bin": {
    "ifgc": "./dist/cli.js",
    "infographic": "./dist/cli.js"
  },
  "engines": {
    "node": "^18.19 || >=20.0"
  },
  "exports": {
    ".": {
      "types": "./dist-types/index.d.ts"
    }
  },
  "types": "./dist-types/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "lint": "eslint src",
    "test": "vitest --run",
    "test:examples": "vitest --run __tests__/integration/examples.test.ts",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@antv/infographic": "^0.2.18",
    "chalk": "^5.6.2",
    "commander": "^14.0.3"
  },
  "devDependencies": {
    "@types/node": "^24.12.2",
    "@typescript-eslint/eslint-plugin": "^8.53.1",
    "@typescript-eslint/parser": "^8.53.1",
    "eslint": "^9.39.2",
    "eslint-plugin-import": "^2.32.0",
    "globals": "^17.0.0",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  },
  "overrides": {
    "tar":"^7.5.13",
    "minimatch":"^3.1.5",
    "lodash-es":"^4.18.1",
    "lodash":"^4.18.1",
    "postcss":"^8.5.13",
    "brace-expansion":"^1.1.14"
  },
  "files": [
    "dist",
    "dist-types",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "keywords": [
    "infographic",
    "infographics",
    "cli",
    "svg",
    "generator",
    "visualization",
    "charts",
    "diagrams",
    "antv",
    "templates",
    "graphics",
    "command-line"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/HK-Zhang/infographic-cli.git"
  },
  "homepage": "https://github.com/HK-Zhang/infographic-cli#readme",
  "bugs": {
    "url": "https://github.com/HK-Zhang/infographic-cli/issues"
  }
}
